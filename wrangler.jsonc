{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "barbuk-us",
  "compatibility_date": "2026-03-27",
  "assets": {
    "directory": "./dist/",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "barbuk.us",
      "custom_domain": true
    },
    {
      "pattern": "www.barbuk.us",
      "custom_domain": true
    }
  ],
  "workers_dev": false
}
