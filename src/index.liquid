<script>
  // Before/After Slider
  const slider = document.getElementById('slider');
  const afterDiv = document.querySelector('.after');
  const container = document.querySelector('.before-after-container');
  const badgeBefore = document.querySelector('.badge-before');
  const badgeAfter = document.querySelector('.badge-after');
  
  let isDragging = false;
  
  function updateSlider(x) {
    const rect = container.getBoundingClientRect();
    const pos = ((x - rect.left) / rect.width) * 100;
    const clampedPos = Math.max(0, Math.min(100, pos));
    
    slider.style.left = clampedPos + '%';
    afterDiv.style.clipPath = `inset(0 ${100 - clampedPos}% 0 0)`;
    
    // Badge visibility based on position
    // When slider is on the left (showing legacy), hide "After" badge
    if (clampedPos < 20) {
      badgeAfter.style.opacity = '0';
    } else {
      badgeAfter.style.opacity = '1';
    }
    
    // When slider is on the right (showing modern), hide "Before" badge
    if (clampedPos > 80) {
      badgeBefore.style.opacity = '0';
    } else {
      badgeBefore.style.opacity = '1';
    }
  }
  
  slider.addEventListener('mousedown', () => isDragging = true);
  document.addEventListener('mouseup', () => isDragging = false);
  
  container.addEventListener('mousemove', (e) => {
    if (isDragging) updateSlider(e.clientX);
  });
  
  container.addEventListener('click', (e) => {
    updateSlider(e.clientX);
  });
  
  // Touch support
  slider.addEventListener('touchstart', () => isDragging = true);
  document.addEventListener('touchend', () => isDragging = false);
  
  container.addEventListener('touchmove', (e) => {
    if (isDragging) {
      e.preventDefault();
      updateSlider(e.touches[0].clientX);
    }
  });
</script>
