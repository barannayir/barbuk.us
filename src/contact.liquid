  <div class="container">
    <div class="trust-grid">
      <div class="trust-item">
        <div class="trust-icon">⚡</div>
        <h3>24-Hour Response</h3>
        <p>We respond to all inquiries within one business day.</p>
      </div>
      
      <div class="trust-item">
        <div class="trust-icon">🔒</div>
        <h3>NDA Available</h3>
        <p>We're happy to sign an NDA before discussing your project.</p>
      </div>
      
      <div class="trust-item">
        <div class="trust-icon">💬</div>
        <h3>Free Consultation</h3>
        <p>30-minute discovery call to understand your needs—no strings attached.</p>
      </div>
      
      <div class="trust-item">
        <div class="trust-icon">📊</div>
        <h3>Transparent Pricing</h3>
        <p>Detailed quotes with clear deliverables and timelines.</p>
      </div>
    </div>
  </div>
</section>
