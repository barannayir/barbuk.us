---
layout: base.liquid
title: Contact Us
description: Get in touch with Barbuk for a free consultation about your legacy system modernization project. We respond within 24 hours.
---

<section class="page-hero">
  <div class="container">
    <h1>Get in Touch</h1>
    <p class="page-subtitle">Let's discuss how we can transform your legacy systems. Free consultation, no pressure.</p>
  </div>
</section>

<section class="contact-section">
  <div class="container">
    <div class="contact-grid">
      
      <div class="contact-form-container">
        <h2>Send Us a Message</h2>
        <p>We typically respond within 24 hours.</p>
        
        <form class="contact-form" id="contactForm">
          <div id="formMessage" class="form-message" style="display: none;"></div>
          
          <div class="form-group">
            <label for="name">Your Name *</label>
            <input type="text" id="name" name="name" required placeholder="John Doe">
          </div>
          
          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email" required placeholder="john@company.com">
          </div>
          
          <div class="form-group">
            <label for="company">Company Name</label>
            <input type="text" id="company" name="company" placeholder="Acme Corporation">
          </div>
          
          <div class="form-group">
            <label for="project">Project Type *</label>
            <select id="project" name="project" required>
              <option value="">Select a service...</option>
              <option value="Legacy System Modernization">Legacy System Modernization</option>
              <option value="UI/UX Redesign">UI/UX Redesign</option>
              <option value="Performance Optimization">Performance Optimization</option>
              <option value="AI Integration">AI Integration</option>
              <option value="Workflow Automation">Workflow Automation</option>
              <option value="Cloud Migration">Cloud Migration</option>
              <option value="Other / Not Sure">Other / Not Sure</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="message">Tell Us About Your Project *</label>
            <textarea id="message" name="message" rows="6" required placeholder="Describe your current system, challenges, and what you'd like to achieve..."></textarea>
          </div>
          
          <button type="submit" class="btn-primary btn-lg" id="submitBtn">
            <span id="btnText">Send Message</span>
            <span id="btnLoader" style="display: none;">Sending...</span>
          </button>
        </form>
        
        <script>
          document.getElementById('contactForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const form = e.target;
            const submitBtn = document.getElementById('submitBtn');
            const btnText = document.getElementById('btnText');
            const btnLoader = document.getElementById('btnLoader');
            const formMessage = document.getElementById('formMessage');
            
            // Disable form
            submitBtn.disabled = true;
            btnText.style.display = 'none';
            btnLoader.style.display = 'inline';
            formMessage.style.display = 'none';
            
            try {
              const formData = new FormData(form);
              
              const response = await fetch('https://barbuk-contact-form.barannayir.workers.dev', {
                method: 'POST',
                body: formData
              });
              
              const result = await response.json();
              
              if (result.success) {
                formMessage.textContent = result.message;
                formMessage.className = 'form-message success';
                formMessage.style.display = 'block';
                form.reset();
              } else {
                throw new Error(result.error || 'Failed to send message');
              }
            } catch (error) {
              formMessage.textContent = error.message || 'Failed to send message. Please try emailing us directly at hello@barbuk.us';
              formMessage.className = 'form-message error';
              formMessage.style.display = 'block';
            } finally {
              submitBtn.disabled = false;
              btnText.style.display = 'inline';
              btnLoader.style.display = 'none';
            }
          });
        </script>
      </div>
      
      <div class="contact-info">
        <h2>Other Ways to Reach Us</h2>
        
        <div class="contact-method">
          <div class="method-icon">📧</div>
          <div class="method-content">
            <h3>Email</h3>
            <a href="mailto:hello@barbuk.us">hello@barbuk.us</a>
            <p>For general inquiries</p>
          </div>
        </div>
        
        <div class="contact-method">
          <div class="method-icon">💼</div>
          <div class="method-content">
            <h3>Business Inquiries</h3>
            <a href="mailto:info@barbuk.us">info@barbuk.us</a>
            <p>For partnerships and enterprise deals</p>
          </div>
        </div>
        
        <div class="contact-method">
          <div class="method-icon">🛠️</div>
          <div class="method-content">
            <h3>Support</h3>
            <a href="mailto:support@barbuk.us">support@barbuk.us</a>
            <p>For existing clients</p>
          </div>
        </div>
        
        <div class="contact-method">
          <div class="method-icon">🐙</div>
          <div class="method-content">
            <h3>GitHub</h3>
            <a href="https://github.com/barbuk-dev" target="_blank">@barbuk-dev</a>
            <p>Check out our open-source projects</p>
          </div>
        </div>
        
        <div class="faq-box">
          <h3>Quick FAQs</h3>
          <div class="faq-item">
            <strong>Q: How long does a typical project take?</strong>
            <p>Most projects: 6-12 weeks. Complex enterprise migrations: 3-6 months. We ship incrementally—you see progress fast.</p>
          </div>
          <div class="faq-item">
            <strong>Q: Do you offer fixed-price quotes?</strong>
            <p>Yes! After a discovery call, we provide a detailed fixed-price proposal. No hourly billing surprises.</p>
          </div>
          <div class="faq-item">
            <strong>Q: Can you work with our existing team?</strong>
            <p>Absolutely. We can augment your team, train your developers, or handle the entire project—whatever works best.</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

